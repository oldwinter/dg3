filters:
  and:
    - topics.containsAny(link("好用网站 - fileclass"))
formulas:
  data: note["date created"]
  Untitled: note["date created"]
views:
  - type: table
    name: Table
    order:
      - file.name
      - 评价
      - url
      - formula.data
      - 一句话评价
    sort:
      - property: 评价
        direction: DESC
  - type: cards
    name: View
    order:
      - file.name
      - file.links
      - 评价
  - type: table
    name: View 2
