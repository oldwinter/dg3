  - type: table
    name: Topics｜Obsidian 资产包
    filters:
      and:
        - type != "note"
        - or:
            - tags.containsAny("obsidian")
            - topics.containsAny("obsidian")
        - or:
            - file.name.contains("底座约束")
            - file.name.contains("输入入口")
            - file.name.contains("视图共振")
            - file.name.contains("工作系统底座")
            - file.name.contains("可编排学习台")
            - file.name.contains("案例形态")
