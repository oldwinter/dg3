      - type
      - status
      - related
      - file.backlinks
      - file.mtime
      - formula.弱连接
    sort:
      - property: file.mtime
        direction: DESC
      - property: file.name
        direction: ASC
  - type: table
    name: Topics｜ClaudeCode
    filters:
      and:
        - type != "note"
        - or:
            - tags.containsAny("claude-code")
            - topics.containsAny("claude-code")
    order:
      - file.name
      - type
      - status
      - related
      - file.backlinks
      - file.mtime
      - formula.弱连接
    sort:
      - property: file.mtime
        direction: DESC
      - property: file.name
        direction: ASC
  - type: table
    name: Topics｜Codex
    filters:
      and:
        - type != "note"
        - or:
            - tags.containsAny("codex")
            - topics.containsAny("codex")
    order:
      - file.name
      - type
      - status
      - related
      - file.backlinks
      - file.mtime
      - formula.弱连接
    sort:
      - property: file.mtime
        direction: DESC
      - property: file.name
        direction: ASC
  - type: table
    name: Topics｜Obsidian
    filters:
      and:
        - type != "note"
        - or:
