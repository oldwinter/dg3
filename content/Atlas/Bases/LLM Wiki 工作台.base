      - type
      - status
      - related
      - file.backlinks
      - file.mtime
      - formula.弱连接
    sort:
      - property: file.name
        direction: ASC
  - type: table
    name: Topics｜Tools
    filters:
      and:
        - type != "note"
        - or:
            - tags.containsAny("raycast", "claude-code", "codex", "obsidian", "skills")
            - topics.containsAny("raycast", "claude-code", "codex", "obsidian", "skills")
    order:
      - file.name
      - type
      - status
