  - type: table
    name: Topics｜Skills Eval
    filters:
      and:
        - type != "note"
        - or:
            - tags.containsAny("skills")
            - topics.containsAny("skills")
        - or:
            - file.name.contains("eval")
            - file.name.contains("Eval")
            - file.name.contains("benchmark")
            - file.name.contains("Benchmark")
            - file.name.contains("smoke")
            - file.name.contains("trigger")
            - file.name.contains("undertrigger")
            - file.name.contains("真实任务")
            - file.name.contains("样本")
            - file.name.contains("验证")
            - file.name.contains("review")
            - file.name.contains("Review")
            - file.name.contains("测量")
            - file.name.contains("description")
            - file.name.contains("frontmatter")
            - file.name.contains("usage")
            - file.name.contains("measurement")
            - file.name.contains("measure")
            - file.name.contains("Measure")
            - file.name.contains("refine")
            - file.name.contains("Refine")
            - file.name.contains("触发质量")
            - file.name.contains("迭代闭环")
    order:
      - file.name
      - type
      - status
      - sources
      - related
      - file.backlinks
      - file.mtime
      - formula.弱连接
    sort:
      - property: file.mtime
        direction: DESC
      - property: file.name
        direction: ASC
  - type: table
    name: Topics｜ClaudeCode+Codex
    filters:
      and:
        - type != "note"
        - or:
