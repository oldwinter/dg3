        direction: DESC
  - type: table
    name: Atlas/MOCs｜最近更新
    filters:
      and:
        - file.inFolder("Atlas/MOCs")
    order:
      - file.name
      - file.mtime
      - file.folder
    sort:
      - property: file.mtime
        direction: DESC
  - type: table
