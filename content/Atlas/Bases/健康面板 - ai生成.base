filters:
  and: []
views:
  - type: table
    name: Cards｜最近更新
    filters:
      and:
        - file.inFolder("Cards")
    order:
      - file.name
      - file.mtime
      - file.folder
    sort:
      - property: file.mtime
        direction: DESC
  - type: table
    name: Spaces/1-Project｜最近更新
    filters:
      and:
        - file.inFolder("Spaces/1-Project")
    order:
      - file.name
      - file.mtime
      - file.folder
    sort:
      - property: file.mtime
        direction: DESC
  - type: table
    name: Spaces/2-Area｜最近更新
    filters:
