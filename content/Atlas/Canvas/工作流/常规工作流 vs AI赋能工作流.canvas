      "height": 380
    },
    {
      "id": "3f407f17ebb6a974",
      "styleAttributes": {},
      "text": "嚼劲脑汁，半天想不出一点东西来。  \n那就只能搜索引擎搜一搜，看能不能找点思路。\n搜着搜着，忘记掉我要干啥来着。",
      "type": "text",
      "x": 613,
      "y": 70,
      "width": 250,
      "height": 170
    },
    {
      "id": "a9b7eb5f6b22668e",
      "styleAttributes": {},
      "text": "全英文的万字长文",
      "type": "text",
      "x": 478,
      "y": 424,
      "width": 250,
      "height": 60
    },
    {
      "id": "13bea44ea9a7faf4",
      "styleAttributes": {},
