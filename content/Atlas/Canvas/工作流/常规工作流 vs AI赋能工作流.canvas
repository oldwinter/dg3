      "height": 60
    },
    {
      "id": "068ffd0381a33399",
      "styleAttributes": {},
      "text": "### 擅长总结，信息提炼和压缩",
      "type": "text",
      "x": -177,
      "y": -566,
      "width": 250,
      "height": 100
    },
    {
      "id": "a2b3b0e3fcfa283e",
      "styleAttributes": {},
      "text": "头脑风暴\n- 取名\n- 项目未来规划",
      "type": "text",
      "x": 750,
      "y": -339,
      "width": 250,
      "height": 139
    },
    {
