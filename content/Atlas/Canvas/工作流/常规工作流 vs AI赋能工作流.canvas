    {
      "id": "58e8c2808f435df0",
      "styleAttributes": {},
      "text": "参考别人的，进行ctrl c ，ctrl v",
      "type": "text",
      "x": 1315,
      "y": 36,
      "width": 275,
      "height": 129
    },
    {
      "id": "967b9de380f2201c",
      "styleAttributes": {},
      "text": "AI赋能工作流",
      "type": "text",
      "x": 1590,
      "y": -63,
      "width": 250,
      "height": 60
    },
    {
      "id": "49c9faf64d123c2b",
      "styleAttributes": {},
      "text": "直接把饭喂我嘴里，直接给我一个能用的表格，能执行的sql语句，能分享的思维导图。",
      "type": "text",
      "x": 1607,
      "y": 36,
      "width": 250,
      "height": 136
    },
    {
      "id": "65113964aabe79fc",
      "styleAttributes": {},
      "text": "- 输出表格\n- 输出代码，输出sql语句\n- 输出思维导图，ppt",
      "type": "text",
      "x": 1372,
      "y": -312,
      "width": 360,
      "height": 170
    },
