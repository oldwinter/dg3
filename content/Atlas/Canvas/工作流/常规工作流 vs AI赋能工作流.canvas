      "type": "text",
      "x": 280,
      "y": -160,
      "width": 250,
      "height": 60
    },
    {
      "id": "6c794e4ac1fa675a",
      "styleAttributes": {},
      "text": "- 借助总结工具，快速预览文章和书，做到心中有数，再决定要不要细看。",
      "type": "text",
      "x": 280,
