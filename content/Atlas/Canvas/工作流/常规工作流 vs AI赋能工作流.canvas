    },
    {
      "id": "288213a9fc8cc229",
      "styleAttributes": {},
      "type": "link",
      "url": "https://kimi.moonshot.cn/chat/cmtpgr2lnl97jg2n5jrg",
      "x": 882,
      "y": 290,
