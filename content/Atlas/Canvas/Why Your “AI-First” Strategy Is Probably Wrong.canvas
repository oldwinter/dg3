      "toNode": "n023",
      "toSide": "left",
      "label": "人类看风险，不盯细节"
    },
    {
      "id": "e012",
      "fromNode": "n022",
      "fromSide": "bottom",
      "toNode": "n024",
      "toSide": "top",
      "label": "异常进入故障闭环"
    },
    {
      "id": "e013",
      "fromNode": "n024",
      "fromSide": "right",
      "toNode": "n025",
      "toSide": "left"
