			"file": "gstack-skills-06-QA评审与验证.canvas",
			"x": 1400,
			"y": 860,
			"width": 360,
			"height": 180,
			"color": "2"
		},
		{
			"id": "f_rel033",
			"type": "file",
			"file": "gstack-skills-07-发布与收尾.canvas",
			"x": 1820,
			"y": 860,
			"width": 360,
			"height": 180,
			"color": "2"
		},
		{
			"id": "f_rel034",
			"type": "file",
			"file": "gstack-skills-08-安全与边界.canvas",
			"x": 2240,
			"y": 860,
			"width": 360,
			"height": 180,
			"color": "2"
		},
		{
			"id": "t_gate035",
			"type": "text",
			"text": "使用建议\n先沿主线找入口，再跳到相关能力域看更细的架构与注意事项。",
			"x": 5360,
			"y": 860,
			"width": 780,
			"height": 180,
			"color": "2"
		}
